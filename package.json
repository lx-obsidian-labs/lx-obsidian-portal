{
  "scripts": {
    "start": "node server.js",
    "dev": "npx wrangler pages dev . --compatibility-date=2024-09-23",
    "build": "node scripts/build.js",
    "deploy": "npm run build && npx wrangler pages deploy dist --project-name lx-obsidian-portal",
    "db:migrate": "npx wrangler d1 execute lx-portal --file=migrations/0001_initial.sql",
    "db:seed": "npx wrangler d1 execute lx-portal --file=migrations/0002_seed.sql"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "jose": "^5.10.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "better-sqlite3": "^12.11.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "wrangler": "^3.100.0"
  }
}
