# Cloudflare Pages Redirects

# Clean URLs: rewrite /page to /page.html (200 = internal rewrite, not a redirect)
/services       /services.html  200
/marketplace    /marketplace.html 200
/portfolio      /portfolio.html 200
/about          /about.html     200
/blog           /blog.html      200
/synapse        /synapse.html   200
/pricing        /contact.html   200
/contact        /contact.html   200
/faq            /faq.html       200

# Legacy .html URLs: redirect to clean URLs
/services.html  /services       301
/marketplace.html /marketplace  301
/portfolio.html /portfolio      301
/about.html     /about          301
/blog.html      /blog           301
/synapse.html   /synapse        301
/pricing.html   /contact        301
/contact.html   /contact        301
/faq.html       /faq            301

# Legacy path support
/shop           /marketplace    301
/apps           /marketplace    301
/catalogue      /marketplace    301
/team           /about          301
/knowledge      /blog           301
/articles       /blog           301
/plans          /contact        301
/support        /contact        301
/help           /faq            301

# Custom 404
/404            /404.html       200

# Dashboard SPA fallback — all /dashboard/* paths serve dashboard/index.html
/dashboard/*  /dashboard/index.html  200
