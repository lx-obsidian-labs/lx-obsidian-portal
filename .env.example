# LX Obsidian Portal — Environment Configuration
# Copy this file to .env and fill in your values

# Server port
PORT=3000

# NVIDIA API key for AI chat (sign up at https://build.nvidia.com)
NVIDIA_API_KEY=

# JWT secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=

# Contact form email (receives form submissions)
CONTACT_EMAIL=hello@lxobsidian.com
